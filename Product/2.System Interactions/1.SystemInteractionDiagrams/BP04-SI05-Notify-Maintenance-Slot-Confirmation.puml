@startuml

partition "BP04 - SI05-Notify Maintenance Slot Confirmation" {
  start
  :Load approved maintenance slot;
  :Build slot confirmation message;
  :Send confirmation email to customer;
  if (Email sent?) then (yes)
    :Record confirmation notification;
  else (no)
    :Record notification failure for retry;
  endif
  stop
}

@enduml
