@startuml

partition "BP03 - SI08-Notify Reject Maintenance Plan" {
  start
  :Receive maintenance plan decision notification request;
  :Load customer contact details;
  :Build notification message with decision details;
  :Send notification email;
  if (Email sent?) then (yes)
    :Record notification as sent;
  else (no)
    :Record notification failure for retry;
  endif
  stop
}

@enduml
